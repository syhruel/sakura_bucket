            <div class="hero-actions">
                <a href="#katalog" class="btn-primary">Lihat Katalog</a>
                <a href="https://wa.me/6281234567890" class="btn-ghost">
                    Hubungi Kami
                    <span class="arrow">→</span>
                </a>
            </div>
            <div class="hero-stats">
                <div>
                    <div class="stat-num">500+</div>
                    <div class="stat-label">Pelanggan Puas</div>
                </div>
                <div>
                    <div class="stat-num">50+</div>
                    <div class="stat-label">Varian Buket</div>
                </div>
                <div>
                    <div class="stat-num">4.9 <i class="ti ti-star-filled" style="font-size:22px;color:var(--pink-400);"
                            aria-hidden="true"></i></div>
                    <div class="stat-label">Rating Rata-rata</div>
                </div>
            </div>
        </div>

        <div class="hero-right">
            <div class="hero-img large" style="position:relative;">
                <img src="https://images.pexels.com/photos/931177/pexels-photo-931177.jpeg?auto=compress&cs=tinysrgb&w=600"
                    onerror="this.onerror=null;this.src='https://placehold.co/600x800/ffd6e7/c72d62?text=Sakura+Bloom'"
                    alt="Buket pink roses">
                <div class="hero-overlay">
                    <div class="hero-overlay-tag">Terlaris</div>
                    <div class="hero-overlay-name">Pink Romance</div>
                    <div class="hero-overlay-price">Rp 185.000</div>
                </div>
            </div>
            <div class="hero-img">
                <img src="https://images.pexels.com/photos/33044/sunflower-sun-summer-yellow.jpg?auto=compress&cs=tinysrgb&w=400"
                    onerror="this.onerror=null;this.src='https://placehold.co/400x300/ffd6e7/c72d62?text=Bunga'"
                    alt="Bunga sunflower">
            </div>
            <div class="hero-img">
                <img src="https://images.pexels.com/photos/56866/garden-rose-red-pink-56866.jpeg?auto=compress&cs=tinysrgb&w=400"
                    onerror="this.onerror=null;this.src='https://placehold.co/400x300/ffd6e7/c72d62?text=Bunga'"
                    alt="Buket bunga peach">
            </div>
        </div>
    </section>

    <!-- FEATURES -->
    <section class="features-section" id="tentang">
        <div class="section-label fade-up">Kenapa Pilih Kami</div>
        <h2 class="section-title fade-up">Kualitas yang Bisa <em>Kamu Rasakan</em></h2>
        <div class="features-grid">
            <div class="feature-card fade-up">
                <div class="feature-icon"><i class="ti ti-plant-2" style="font-size:26px;color:var(--pink-500);"
                        aria-hidden="true"></i></div>
                <div class="feature-title">Bunga Segar Pilihan</div>
                <p class="feature-desc">Kami memilih bunga terbaik setiap hari langsung dari petani lokal dan pasar
